{
	"name": "vms",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"prepare": "husky",
		"start": "npm run dev",
		"dev": "wrangler dev src/index.ts",
		"generate:types": "wrangler types src/env.d.ts",
		"deploy:dev": "wrangler deploy --minify --env dev",
		"deploy:prod": "wrangler deploy --minify --env production",
		"format": "dprint fmt --staged",
		"typecheck": "tsc --noEmit",
		"lint:js": "eslint",
		"lint": "npm run typecheck && npm run lint:js",
		"db:setup": "wrangler d1 migrations apply vms-local --local --persist-to=.wrangler/state",
		"db:seed": "wrangler d1 execute vms-local --local --persist-to=.wrangler/state --file=./seeds/seed-data.sql"
	},
	"dependencies": {
		"@hono/swagger-ui": "0.5.1",
		"@hono/zod-openapi": "0.19.4",
		"hono": "^4.7.6",
		"resend": "^4.5.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250412.0",
		"@types/node": "^22.14.1",
		"@typescript-eslint/eslint-plugin": "8.29.1",
		"@typescript-eslint/parser": "8.29.1",
		"dprint": "0.49.1",
		"eslint": "9.24.0",
		"globals": "16.0.0",
		"husky": "9.1.7",
		"typescript": "5.8.3",
		"vitest": "^3.1.1",
		"wrangler": "^4.10.0",
		"zod": "^3.24.2"
	},
	"volta": {
		"node": "22.12.0"
	},
	"overrides": {
		"is-core-module": "npm:@nolyfill/is-core-module@^1"
	}
}
