{
	"name": "vms",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"prepare": "husky",
		"start": "npm run dev",
		"dev": "wrangler dev src/index.ts",
		"deploy": "wrangler deploy --minify",
		"deploy:prod": "wrangler deploy --minify --env production",
		"format": "dprint fmt --staged",
		"typecheck": "tsc --noEmit",
		"lint:js": "eslint --fix",
		"lint": "npm run typecheck && npm run lint:js",
		"db:setup": "wrangler d1 migrations apply vms-local --local --persist-to=.wrangler/state",
		"db:seed": "wrangler d1 execute vms-local --local --persist-to=.wrangler/state --file=./seeds/seed-data.sql"
	},
	"dependencies": {
		"@hono/zod-openapi": "0.19.2",
		"@sendgrid/mail": "^8.1.4",
		"date-fns": "^4.1.0",
		"hono": "^4.6.17"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250327.0",
		"@types/node": "^22.10.2",
		"@typescript-eslint/eslint-plugin": "8.29.0",
		"@typescript-eslint/parser": "8.29.0",
		"dprint": "0.49.1",
		"eslint": "9.23.0",
		"globals": "16.0.0",
		"husky": "9.1.7",
		"typescript": "5.8.2",
		"vitest": "^3.1.1",
		"wrangler": "^4.6.0",
		"zod": "^3.24.1"
	},
	"volta": {
		"node": "22.12.0"
	},
	"overrides": {
		"is-core-module": "npm:@nolyfill/is-core-module@^1"
	}
}
