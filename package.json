{
	"name": "vms",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"prepare": "husky",
		"start": "npm run dev",
		"dev": "wrangler dev src/index.ts",
		"generate:types": "wrangler types src/env.d.ts",
		"deploy:dev": "wrangler deploy --minify --env dev",
		"deploy:prod": "wrangler deploy --minify --env production",
		"format": "dprint fmt --staged",
		"typecheck": "tsc --noEmit",
		"lint:js": "eslint",
		"lint": "npm run typecheck && npm run lint:js",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"db:setup": "wrangler d1 migrations apply vms-local --local",
		"db:seed": "wrangler d1 execute vms-local --local --file=./seeds/seed-data.sql"
	},
	"dependencies": {
		"@hono/swagger-ui": "0.5.1",
		"@hono/zod-openapi": "0.19.4",
		"hono": "^4.7.6",
		"resend": "^4.5.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.8.32",
		"@types/node": "^22.15.21",
		"@typescript-eslint/eslint-plugin": "8.32.1",
		"@typescript-eslint/parser": "8.32.1",
		"@vitest/coverage-v8": "^3.1.4",
		"dprint": "0.50.0",
		"eslint": "9.27.0",
		"globals": "16.1.0",
		"husky": "9.1.7",
		"typescript": "5.8.3",
		"wrangler": "^4.10.0",
		"zod": "^3.25.28"
	},
	"volta": {
		"node": "22.12.0"
	},
	"overrides": {
		"is-core-module": "npm:@nolyfill/is-core-module@^1"
	}
}
