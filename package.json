{
	"name": "vms",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"prepare": "husky",
		"start": "npm run dev",
		"dev": "wrangler dev src/index.ts",
		"deploy": "wrangler deploy --minify",
		"deploy:prod": "wrangler deploy --minify --env production",
		"format": "dprint fmt --staged",
		"typecheck": "tsc --noEmit",
		"lint:js": "eslint --fix",
		"lint": "npm run typecheck && npm run lint:js",
		"db:setup": "wrangler d1 migrations apply vms-local --local --persist-to=db",
		"db:setup:linux-file-auth": "./migration/wrangler-development-script.sh"
	},
	"dependencies": {
		"@sendgrid/mail": "^8.1.4",
		"@hono/zod-openapi": "0.19.0",
		"hono": "^4.7.2"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250224.0",
		"@types/node": "^22.10.2",
		"@typescript-eslint/eslint-plugin": "8.25.0",
		"@typescript-eslint/parser": "8.25.0",
		"dprint": "0.49.0",
		"eslint": "9.21.0",
		"globals": "16.0.0",
		"husky": "9.1.7",
		"typescript": "5.8.2",
		"wrangler": "^3.111.0",
		"zod": "^3.24.1",
		"vitest": "^3.0.7"
	},
	"volta": {
		"node": "22.12.0"
	},
	"overrides": {
		"is-core-module": "npm:@nolyfill/is-core-module@^1"
	}
}
